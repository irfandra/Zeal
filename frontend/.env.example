# Required for WalletConnect login flow
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
EXPO_PUBLIC_WALLETCONNECT_RELAY_URL=wss://relay.walletconnect.com
EXPO_PUBLIC_WALLETCONNECT_NATIVE_REDIRECT=zeal://wc
EXPO_PUBLIC_WALLETCONNECT_UNIVERSAL_REDIRECT=

# Polygon-like runtime profile (single source of truth for chain/rpc on frontend)
EXPO_PUBLIC_POLYGON_LIKE_CHAIN_ID=80002
EXPO_PUBLIC_POLYGON_LIKE_RPC_URL=https://rpc-amoy.polygon.technology
EXPO_PUBLIC_API_BASE_URL=

# Default recipient for "Email QRs" batch action
EXPO_PUBLIC_PLATFORM_QR_EMAIL=zealsysinfo@gmail.com
