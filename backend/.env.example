# Database Configuration
DB_USERNAME=root
DB_PASSWORD=password

# Host ports (used directly by docker-compose.yml)
MYSQL_HOST_PORT=3306
HARDHAT_HOST_PORT=8545
BACKEND_HOST_PORT=8080

# Polygon-like runtime profile (single source of truth)
POLYGON_LIKE_CHAIN_ID=80002
POLYGON_LIKE_RPC_URL=http://hardhat:8545
POLYGON_LIKE_INITIAL_BASE_FEE_WEI=30000000000
POLYGON_LIKE_MINING_INTERVAL_MS=2000
POLYGON_LIKE_BLOCK_GAS_LIMIT=30000000

# Database Mode Configuration
# Options:
# - "create"   : First injection - Drops and recreates schema on startup (use only for initial setup)
# - "validate" : Development mode - Only validates schema, no modifications (recommended for development with Flyway)
# - "update"   : Updates schema automatically (use with caution)
# - "none"     : No schema operations (use when Flyway handles everything)
DATABASE_MODE=validate

# SMTP Configuration (email verification/reset)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# JWT Configuration
# Required: backend will not start without this value
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-12345678901234567890

# Web3 Configuration
# Contract + signer only. RPC/chain tuning comes from POLYGON_LIKE_* above.
CONTRACT_ADDRESS=
PRIVATE_KEY=
# Optional brand signer map so mint gas is paid by each brand wallet.
# Format: WEB3_BRAND_PRIVATE_KEYS=wallet1:privateKey1,wallet2:privateKey2
WEB3_BRAND_PRIVATE_KEYS=
# Static gas price used by list-modal mint fee estimate (Apr-1 Polygon reference).
WEB3_ESTIMATE_APRIL_FIRST_POLYGON_GAS_PRICE_WEI=30000000000

# Manual deployer (one-time when hardhat state resets):
# docker compose -f backend/docker-compose.yml run --rm contract-deployer

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Frontend deep link used in password reset emails
FRONTEND_RESET_PASSWORD_DEEPLINK=zeal://changepassword
